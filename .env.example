# Database Settings (PostgreSQL hosted database e.g., Supabase, Neon, or Vercel Postgres)
DATABASE_URL="postgresql://username:password@hostname:5432/database?schema=public"

# NextAuth Settings
# Generate a secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-session-secret-key-32-chars-long"
NEXTAUTH_URL="http://localhost:3000"

# Base URL for Payments redirects
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# PhonePe Payment Gateway Credentials (Sandbox credentials are listed here)
# For Sandbox, use Merchant ID: PGTESTPAYUAT
PHONEPE_MERCHANT_ID="PGTESTPAYUAT"
# For Sandbox, use Salt Key: 099eb0cd-02cf-4e2a-8aca-3e6c6aff0399
PHONEPE_SALT_KEY="099eb0cd-02cf-4e2a-8aca-3e6c6aff0399"
# For Sandbox, use Salt Index: 1
PHONEPE_SALT_INDEX="1"
# Environment: "sandbox" or "production"
PHONEPE_ENV="sandbox"

# SMS OTP Provider (e.g. MSG91 or Twilio)
SMS_OTP_PROVIDER="mock" # "mock", "msg91", "twilio"
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# OAuth Credentials (Optional - sandbox authentication fallback is active)
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
APPLE_CLIENT_ID="your-apple-oauth-client-id"
APPLE_CLIENT_SECRET="your-apple-oauth-client-secret"
